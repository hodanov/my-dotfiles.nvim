{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "bash": "~/.copilot/hooks/goimports.sh",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/markdown-format.sh",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/shfmt.sh",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "~/.copilot/hooks/prettier.sh",
        "timeoutSec": 10
      }
    ]
  }
}
